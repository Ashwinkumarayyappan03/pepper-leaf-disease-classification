# Copy to .env and fill in real values before running

# App
DEBUG=true

# Security
SECRET_KEY=change-this-to-a-random-64-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
DATABASE_URL=sqlite:///./pepperleaf.db
# For Postgres in production:
# DATABASE_URL=postgresql://user:password@localhost:5432/pepperleaf

# External APIs
ANTHROPIC_API_KEY=sk-ant-dummy
OPENWEATHER_API_KEY=dummy

# ML
MODEL_PATH=ml/saved_models/pepper_disease_model.h5
IMG_SIZE=96
